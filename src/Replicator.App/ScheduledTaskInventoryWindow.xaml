<Window x:Class="Replicator.App.ScheduledTaskInventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scheduled Tasks"
        Height="520"
        Width="960"
        MinHeight="420"
        MinWidth="760"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderSubtleBrush}" />
            <Setter Property="RowBackground" Value="{StaticResource InputBackgroundBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{StaticResource PanelBackgroundBrush}" />
            <Setter Property="HeadersVisibility" Value="Column" />
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style TargetType="{x:Type DataGridCell}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}" />
            <Setter Property="Padding" Value="8,5" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="0,0,0,12">
            <TextBlock Text="Scheduled Tasks"
                       FontSize="22"
                       FontWeight="SemiBold" />
            <TextBlock x:Name="SummaryTextBlock"
                       Margin="0,5,0,0"
                       Foreground="{StaticResource TextSecondaryBrush}" />
        </StackPanel>

        <DataGrid x:Name="TasksGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="State"
                                    Binding="{Binding InventoryState}"
                                    Width="120" />
                <DataGridTextColumn Header="Profile"
                                    Binding="{Binding ProfileName}"
                                    Width="170" />
                <DataGridTextColumn Header="Task"
                                    Binding="{Binding TaskName}"
                                    Width="260" />
                <DataGridTextColumn Header="Reason"
                                    Binding="{Binding Reason}"
                                    Width="*" />
                <DataGridTextColumn Header="Last Run"
                                    Binding="{Binding LastRunTime}"
                                    Width="155" />
                <DataGridTextColumn Header="Result"
                                    Binding="{Binding LastResult}"
                                    Width="85" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Close"
                    Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
