<Window
    x:Class="Replicator.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Replicator.App.Converters"
    Title="Replicator">
    <Grid x:Name="RootGrid"
          Background="{StaticResource AppBackgroundBrush}"
          Margin="16">
        <Grid.Resources>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12">
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Profiles"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            Spacing="8">
                    <Button Content="New Profile"
                            Command="{Binding NewProfileCommand}" />
                    <Button Content="Delete"
                            Command="{Binding DeleteProfileCommand}"
                            Visibility="{Binding ActionSurface.ShowDeleteProfile, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>

                <ListView x:Name="ProfilesList"
                          Grid.Row="2"
                          ItemsSource="{Binding Profiles}"
                          SelectedItem="{Binding SelectedProfile, Mode=TwoWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Grid Grid.Column="2"
              RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <IconSourceElement IconSource="{StaticResource Logo.Mark}"
                                               Width="28"
                                               Height="28" />
                            <TextBlock Text="{Binding HeaderText}"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                        <TextBlock Text="{Binding ActionSurface.TaskSummaryText}"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding AvailabilityText}"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="{Binding DriveSecurityText}"
                                       Foreground="{StaticResource TextMutedBrush}" />
                            <Button Content="Check as Admin"
                                    Command="{Binding CheckDriveSecurityAsAdminCommand}"
                                    Visibility="{Binding ActionSurface.ShowElevatedDriveSecurity, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>
                        <ProgressBar IsIndeterminate="True"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>

                    <InfoBar Grid.Column="1"
                             IsOpen="True"
                             IsClosable="False"
                             Title="{Binding Status.Text}"
                             MaxWidth="360" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Visibility="{Binding TaskInventory.IsActionCenterVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Scheduled task review needed"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource WarningBrush}" />
                        <TextBlock Text="{Binding TaskInventory.Summary}"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8">
                        <Button Content="Review Tasks"
                                Command="{Binding ReviewTaskInventoryCommand}" />
                        <Button Content="Repair Task"
                                Command="{Binding RepairSelectedInventoryTaskCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="2">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource PanelBackgroundBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14">
                        <Grid ColumnSpacing="10" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Name" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBox x:Name="NameTextBox" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Form.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="1" Text="Source" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBox x:Name="SourcePathTextBox" Grid.Row="1" Grid.Column="1" Text="{Binding Form.SourcePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Row="1" Grid.Column="2" Content="Browse" Command="{Binding BrowseSourceCommand}" />

                            <TextBlock Grid.Row="2" Text="{Binding Form.DestinationLabel}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBox x:Name="DestinationPathTextBox" Grid.Row="2" Grid.Column="1" Text="{Binding Form.DestinationPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Row="2" Grid.Column="2" Content="Browse" Command="{Binding BrowseDestinationCommand}" />

                            <TextBlock Grid.Row="3" Text="Profile mode" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <ComboBox x:Name="ModeComboBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" SelectedItem="{Binding Form.Mode, Mode=TwoWay}" />

                            <TextBlock Grid.Row="4" Text="Cadence" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <ComboBox x:Name="CadenceComboBox" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" SelectedItem="{Binding Form.Cadence, Mode=TwoWay}" />

                            <TextBlock Grid.Row="5" Text="Start time" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBox x:Name="TimeTextBox" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Form.TimeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="6" Text="Weekly day" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <ComboBox x:Name="DayOfWeekComboBox" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" SelectedItem="{Binding Form.DayOfWeek, Mode=TwoWay}" />

                            <TextBlock Grid.Row="7" Text="{Binding Form.IntervalLabel}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBox x:Name="IntervalTextBox" Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Form.IntervalText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <StackPanel Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="18">
                                <CheckBox Content="Schedule enabled" IsChecked="{Binding Form.ScheduleEnabled, Mode=TwoWay}" />
                                <CheckBox Content="Dry run" IsChecked="{Binding Form.DryRun, Mode=TwoWay}" />
                                <CheckBox Content="Mirror deletes" IsChecked="{Binding Form.MirrorDeletes, Mode=TwoWay}" />
                            </StackPanel>

                            <TextBlock Grid.Row="9" Text="Excludes" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Top" />
                            <TextBox Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="2" MinHeight="96" AcceptsReturn="True" TextWrapping="NoWrap" Text="{Binding Form.ExcludePatternsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{StaticResource PanelBackgroundBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Visibility="{Binding TaskInventory.IsReviewOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ListView ItemsSource="{Binding TaskInventory.Items}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="70" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding InventoryState}" />
                                        <TextBlock Grid.Column="1" Text="{Binding ProfileName}" />
                                        <TextBlock Grid.Column="2" Text="{Binding TaskName}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="3" Text="{Binding Reason}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="4" Text="{Binding LastRunTime}" />
                                        <TextBlock Grid.Column="5" Text="{Binding LastResult}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Grid>
            </ScrollViewer>

            <Border Grid.Row="3"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="120" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Save Profile" Command="{Binding SaveProfileCommand}" Visibility="{Binding ActionSurface.ShowSaveProfile, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Generate Script" Command="{Binding GenerateScriptCommand}" Visibility="{Binding ActionSurface.ShowGenerateScript, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="{Binding ActionSurface.InstallTaskLabel}" Command="{Binding InstallTaskCommand}" Visibility="{Binding ActionSurface.ShowInstallTask, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Run Now" Command="{Binding RunNowCommand}" Visibility="{Binding ActionSurface.ShowRunNow, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Start Scheduled Task" Command="{Binding StartScheduledTaskCommand}" Visibility="{Binding ActionSurface.ShowStartScheduledTask, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Preview Dry Run" Command="{Binding PreviewDryRunCommand}" Visibility="{Binding ActionSurface.ShowPreviewDryRun, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Enable Task" Command="{Binding EnableTaskCommand}" Visibility="{Binding ActionSurface.ShowEnableTask, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Disable Task" Command="{Binding DisableTaskCommand}" Visibility="{Binding ActionSurface.ShowDisableTask, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Remove Task" Command="{Binding RemoveTaskCommand}" Visibility="{Binding ActionSurface.ShowRemoveTask, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Refresh Status" Command="{Binding RefreshStatusCommand}" Visibility="{Binding ActionSurface.ShowRefreshStatus, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Cancel" Command="{Binding CancelOperationCommand}" Visibility="{Binding ActionSurface.ShowCancelOperation, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Prepare Shuttle" Command="{Binding PrepareShuttleCommand}" Visibility="{Binding ActionSurface.ShowPrepareShuttle, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Depart" Command="{Binding DepartShuttleCommand}" Visibility="{Binding ActionSurface.ShowDepartShuttle, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Dock Shuttle" Command="{Binding DockShuttleCommand}" Visibility="{Binding ActionSurface.ShowDockShuttle, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="Receive Changes" Command="{Binding ReceiveShuttleCommand}" Visibility="{Binding ActionSurface.ShowReceiveShuttle, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                    <TextBox x:Name="OutputTextBox" Grid.Row="1" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" Text="{Binding OutputText}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
