<Window x:Class="Replicator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Replicator"
        Height="760"
        Width="1180"
        MinHeight="680"
        MinWidth="980"
        Loaded="Window_Loaded"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource PanelBorderStyle}"
                Padding="12">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Profiles"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />
                    <Button x:Name="NewProfileButton"
                            Content="New Profile"
                            Click="NewProfile_Click" />
                    <Button x:Name="DeleteProfileButton"
                            Content="Delete Profile"
                            Click="DeleteProfile_Click" />
                </StackPanel>

                <ListBox x:Name="ProfilesList"
                         DisplayMemberPath="Name"
                         SelectionChanged="ProfilesList_SelectionChanged"
                         Margin="0,8,0,0" />
            </DockPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="14"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource Logo.Mark}"
                                   Width="30"
                                   Height="30"
                                   Margin="0,0,12,0"
                                   VerticalAlignment="Center" />
                            <TextBlock x:Name="HeaderTextBlock"
                                       Text="Replicator"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock x:Name="TaskSummaryTextBlock"
                                   Text="No profile selected."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,4,0,0" />
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Image Source="{StaticResource Icon.Drive}"
                                   Width="14"
                                   Height="14"
                                   VerticalAlignment="Top"
                                   Margin="0,1,0,0" />
                            <TextBlock x:Name="AvailabilityTextBlock"
                                       Grid.Column="1"
                                       Text="Availability not checked."
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </Grid>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Image Source="{StaticResource Icon.Locked}"
                                   Width="14"
                                   Height="14"
                                   VerticalAlignment="Top"
                                   Margin="0,1,0,0" />
                            <TextBlock x:Name="DriveSecurityTextBlock"
                                       Grid.Column="1"
                                       Text="Drive security not checked."
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </Grid>
                        <ProgressBar x:Name="ActivityProgressBar"
                                     Height="6"
                                     Width="420"
                                     HorizontalAlignment="Left"
                                     Margin="0,10,0,0"
                                     Visibility="Collapsed"
                                     IsIndeterminate="True" />
                    </StackPanel>

                    <TextBlock x:Name="StatusTextBlock"
                               Grid.Column="1"
                               Foreground="{StaticResource StatusSuccessBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextAlignment="Right" />
                </Grid>
            </Border>

            <Border x:Name="TaskActionCenterPanel"
                    Grid.Row="1"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="12"
                    Margin="0,0,0,12"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="TaskActionCenterTitleTextBlock"
                                   Text="Scheduled task review needed"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource WarningBrush}" />
                        <TextBlock x:Name="TaskActionCenterSummaryTextBlock"
                                   Margin="0,3,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>

                    <WrapPanel Grid.Column="1"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0">
                        <Button x:Name="ReviewTaskInventoryButton"
                                Content="Review Tasks"
                                Click="ReviewTaskInventory_Click" />
                        <Button x:Name="RepairSelectedInventoryTaskButton"
                                Content="Repair Task"
                                Click="RepairSelectedInventoryTask_Click" />
                    </WrapPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto">
                <Border Style="{StaticResource PanelBorderStyle}"
                        Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="145" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Name" />
                        <TextBox x:Name="NameTextBox" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" />

                        <Label Grid.Row="1" Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{StaticResource Icon.Source}"
                                       Width="14"
                                       Height="14"
                                       Margin="0,0,7,0"
                                       VerticalAlignment="Center" />
                                <TextBlock Text="Source"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Label>
                        <TextBox x:Name="SourcePathTextBox" Grid.Row="1" Grid.Column="1" Margin="0,6,8,0" />
                        <Button Grid.Row="1" Grid.Column="2" Content="Browse" Click="BrowseSource_Click" Margin="0,6,0,0" />

                        <Label x:Name="DestinationLabel" Grid.Row="2" Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <Image x:Name="DestinationLabelIcon"
                                       Source="{StaticResource Icon.Destination}"
                                       Width="14"
                                       Height="14"
                                       Margin="0,0,7,0"
                                       VerticalAlignment="Center" />
                                <TextBlock x:Name="DestinationLabelTextBlock"
                                           Text="Destination"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Label>
                        <TextBox x:Name="DestinationPathTextBox" Grid.Row="2" Grid.Column="1" Margin="0,6,8,0" />
                        <Button Grid.Row="2" Grid.Column="2" Content="Browse" Click="BrowseDestination_Click" Margin="0,6,0,0" />

                        <Label Grid.Row="3" Grid.Column="0" Content="Profile mode" />
                        <ComboBox x:Name="ModeComboBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,6,0,0" SelectionChanged="ModeComboBox_SelectionChanged" />

                        <Label Grid.Row="4" Grid.Column="0" Content="Cadence" />
                        <ComboBox x:Name="CadenceComboBox" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,6,0,0" SelectionChanged="CadenceComboBox_SelectionChanged" />

                        <Label Grid.Row="5" Grid.Column="0" Content="Start time" />
                        <TextBox x:Name="TimeTextBox" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,6,0,0" />

                        <Label Grid.Row="6" Grid.Column="0" Content="Weekly day" />
                        <ComboBox x:Name="DayOfWeekComboBox" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,6,0,0" />

                        <Label x:Name="IntervalLabel" Grid.Row="7" Grid.Column="0" Content="Hourly interval" />
                        <TextBox x:Name="IntervalHoursTextBox" Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,6,0,0" />

                        <Label Grid.Row="8" Grid.Column="0" Content="Options" />
                        <StackPanel Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,8,0,0">
                            <CheckBox x:Name="ScheduleEnabledCheckBox" Content="Schedule enabled" Margin="0,0,18,0" VerticalAlignment="Center" />
                            <CheckBox x:Name="DryRunCheckBox" Content="Dry run" Margin="0,0,18,0" VerticalAlignment="Center" />
                            <CheckBox x:Name="MirrorDeletesCheckBox" Content="Mirror deletes" VerticalAlignment="Center" />
                        </StackPanel>

                        <Label Grid.Row="9" Grid.Column="0" Content="Excludes" VerticalAlignment="Top" />
                        <TextBox x:Name="ExcludePatternsTextBox"
                                 Grid.Row="9"
                                 Grid.Column="1"
                                 Grid.ColumnSpan="2"
                                 Margin="0,8,0,0"
                                 MinHeight="96"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap" />

                        <Label Grid.Row="10" Grid.Column="0" Content="Task name" />
                        <TextBlock x:Name="TaskNameTextBlock" Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,10,0,0" Foreground="{StaticResource TextSecondaryBrush}" />

                        <Label Grid.Row="11" Grid.Column="0" Content="Next run" />
                        <TextBlock x:Name="NextRunTextBlock" Grid.Row="11" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,10,0,0" Foreground="{StaticResource TextSecondaryBrush}" />

                        <Label Grid.Row="12" Grid.Column="0" Content="Last run" />
                        <TextBlock x:Name="LastRunTextBlock" Grid.Row="12" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,10,0,0" Foreground="{StaticResource TextSecondaryBrush}" />

                        <Label Grid.Row="13" Grid.Column="0" Content="Latest log" />
                        <TextBlock x:Name="LatestLogTextBlock" Grid.Row="13" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,10,0,0" Foreground="{StaticResource TextSecondaryBrush}" />

                        <Label Grid.Row="14" Grid.Column="0" Content="Run summary" />
                        <TextBlock x:Name="RunSummaryTextBlock" Grid.Row="14" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,10,0,0" Foreground="{StaticResource TextPrimaryBrush}" />
                    </Grid>
                </Border>
            </ScrollViewer>

            <Border Grid.Row="3"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="14"
                    Margin="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="120" />
                    </Grid.RowDefinitions>

                    <WrapPanel Grid.Row="0">
                        <Button x:Name="SaveProfileButton" Content="Save Profile" Click="SaveProfile_Click" />
                        <Button x:Name="GenerateScriptButton" Content="Generate Script" Click="GenerateScript_Click" />
                        <Button x:Name="InstallTaskButton" Content="Install Task" Click="InstallTask_Click" />
                        <Button x:Name="RunNowButton" Content="Run Now" Click="RunNow_Click" />
                        <Button x:Name="StartScheduledTaskButton" Content="Start Scheduled Task" Click="RunTask_Click" />
                        <Button x:Name="PreviewDryRunButton" Content="Preview Dry Run" Click="RunScriptDry_Click" />
                        <Button x:Name="EnableTaskButton" Content="Enable Task" Click="EnableTask_Click" />
                        <Button x:Name="DisableTaskButton" Content="Disable Task" Click="DisableTask_Click" />
                        <Button x:Name="RemoveTaskButton" Content="Remove Task" Click="RemoveTask_Click" />
                        <Button x:Name="RefreshStatusButton" Content="Refresh Status" Click="RefreshStatus_Click" />
                        <Button x:Name="CancelOperationButton" Content="Cancel" Click="CancelOperation_Click" Visibility="Collapsed" />
                        <Button x:Name="PrepareShuttleButton" Content="Prepare Shuttle" Click="PrepareShuttle_Click" />
                        <Button x:Name="DepartShuttleButton" Content="Depart" Click="DepartShuttle_Click" />
                        <Button x:Name="DockShuttleButton" Content="Dock Shuttle" Click="DockShuttle_Click" />
                        <Button x:Name="ReceiveShuttleButton" Content="Receive Changes" Click="ReceiveShuttle_Click" />
                    </WrapPanel>

                    <TextBox x:Name="OutputTextBox"
                             Grid.Row="1"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="12"
                             Margin="0,8,0,0" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
