<Application x:Class="Replicator.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Brand/Theme.xaml" />
                <ResourceDictionary Source="Themes/Brand/Compatibility.xaml" />
                <ResourceDictionary Source="Themes/Brand/AppControls.xaml" />
                <ResourceDictionary Source="Themes/Brand/Icons.xaml" />
                <ResourceDictionary Source="Themes/Brand/Logo.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
