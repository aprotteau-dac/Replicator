<?xml version="1.0" encoding="utf-8"?>
<!--
  Replicator · Compatibility.xaml · v1.0.1

  Alias layer mapping the existing Replicator.App resource keys
  (AppBackgroundBrush, TextPrimaryBrush, etc.) onto the v1.0 brand tokens
  (Brush.Bg.Floor, Brush.Ink.Bone, …).

  Drop this AFTER Theme.xaml in App.xaml's merged dictionaries. Views that
  reference the old keys keep working unchanged; new views should use the
  v1.0 brand keys (`Brush.*`) directly.

  When all views have been migrated to the brand keys, remove this file from
  App.xaml's MergedDictionaries.

  STATUS COLOR MIGRATION
  ──────────────────────
  The old theme used green for success (StatusSuccessBrush). The brand rule
  is "bone is for ok, not green." This file maps StatusSuccessBrush onto
  Brush.Status.Ok (bone) so the change happens uniformly. If you have a
  specific surface where you want to keep the green semantically (e.g. a
  diff view), reference a local brush instead of the alias.
-->
<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ─── SURFACE ─────────────────────────────────────────────────────── -->
  <SolidColorBrush x:Key="AppBackgroundBrush"        Color="{StaticResource Color.Bg.Floor}"/>
  <SolidColorBrush x:Key="WindowBackgroundBrush"     Color="{StaticResource Color.Bg.Floor}"/>
  <SolidColorBrush x:Key="PanelBackgroundBrush"      Color="{StaticResource Color.Bg.Panel}"/>
  <SolidColorBrush x:Key="CardBackgroundBrush"       Color="{StaticResource Color.Bg.Panel}"/>
  <SolidColorBrush x:Key="RaisedBackgroundBrush"     Color="{StaticResource Color.Bg.Raise}"/>
  <SolidColorBrush x:Key="HoverBackgroundBrush"      Color="{StaticResource Color.Bg.Raise}"/>
  <SolidColorBrush x:Key="SelectedBackgroundBrush"   Color="{StaticResource Color.Bg.RaisePlus}"/>

  <!-- ─── TEXT / INK ──────────────────────────────────────────────────── -->
  <SolidColorBrush x:Key="TextPrimaryBrush"          Color="{StaticResource Color.Ink.Bone}"/>
  <SolidColorBrush x:Key="ForegroundBrush"           Color="{StaticResource Color.Ink.Bone}"/>
  <SolidColorBrush x:Key="TextSecondaryBrush"        Color="{StaticResource Color.Ink.BoneMute}"/>
  <SolidColorBrush x:Key="TextMutedBrush"            Color="{StaticResource Color.Ink.BoneMute}"/>
  <SolidColorBrush x:Key="TextDimBrush"              Color="{StaticResource Color.Ink.BoneDim}"/>
  <SolidColorBrush x:Key="TextDisabledBrush"         Color="{StaticResource Color.Ink.BoneDim}"/>

  <!-- ─── LINES / BORDERS ─────────────────────────────────────────────── -->
  <SolidColorBrush x:Key="BorderBrush"               Color="{StaticResource Color.Line}"/>
  <SolidColorBrush x:Key="SeparatorBrush"            Color="{StaticResource Color.Line}"/>
  <SolidColorBrush x:Key="BorderStrongBrush"         Color="{StaticResource Color.Line.Hi}"/>

  <!-- ─── ACCENT / PRIMARY ────────────────────────────────────────────── -->
  <SolidColorBrush x:Key="AccentBrush"               Color="{StaticResource Color.Red.Primary}"/>
  <SolidColorBrush x:Key="PrimaryBrush"              Color="{StaticResource Color.Red.Primary}"/>
  <SolidColorBrush x:Key="PrimaryHoverBrush"         Color="{StaticResource Color.Red.Deep}"/>

  <!-- ─── STATUS  (the rename that matters) ───────────────────────────── -->
  <!-- Old "success" was green. New: bone. See note at top of file. -->
  <SolidColorBrush x:Key="StatusSuccessBrush"        Color="{StaticResource Color.Status.Ok}"/>
  <SolidColorBrush x:Key="SuccessBrush"              Color="{StaticResource Color.Status.Ok}"/>
  <SolidColorBrush x:Key="OkBrush"                   Color="{StaticResource Color.Status.Ok}"/>

  <SolidColorBrush x:Key="WarningBrush"              Color="{StaticResource Color.Status.Alarm}"/>
  <SolidColorBrush x:Key="StatusWarningBrush"        Color="{StaticResource Color.Status.Alarm}"/>
  <SolidColorBrush x:Key="LockedBrush"               Color="{StaticResource Color.Status.Alarm}"/>

  <SolidColorBrush x:Key="ErrorBrush"                Color="{StaticResource Color.Status.Danger}"/>
  <SolidColorBrush x:Key="StatusErrorBrush"          Color="{StaticResource Color.Status.Danger}"/>
  <SolidColorBrush x:Key="DangerBrush"               Color="{StaticResource Color.Status.Danger}"/>

  <SolidColorBrush x:Key="InfoBrush"                 Color="{StaticResource Color.Status.Info}"/>
  <SolidColorBrush x:Key="StatusInfoBrush"           Color="{StaticResource Color.Status.Info}"/>

  <SolidColorBrush x:Key="WaitBrush"                 Color="{StaticResource Color.Status.Wait}"/>
  <SolidColorBrush x:Key="PendingBrush"              Color="{StaticResource Color.Status.Wait}"/>

  <!-- ─── BUTTON STYLE ALIASES ────────────────────────────────────────── -->
  <!-- If the existing app uses these style keys, they pick up the brand
       buttons. New views should reference Button.Primary / Button.Secondary
       directly. -->
  <Style x:Key="PrimaryButtonStyle"   TargetType="Button" BasedOn="{StaticResource Button.Primary}"/>
  <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource Button.Secondary}"/>
  <Style x:Key="ActionButtonStyle"    TargetType="Button" BasedOn="{StaticResource Button.Primary}"/>

  <!-- Existing MainWindow panels reference this key directly. -->
  <Style x:Key="PanelBorderStyle" TargetType="Border" BasedOn="{StaticResource Surface.Panel}"/>

  <!-- ─── TEXT STYLE ALIASES ──────────────────────────────────────────── -->
  <Style x:Key="DisplayTextStyle"  TargetType="TextBlock" BasedOn="{StaticResource Text.Display}"/>
  <Style x:Key="TitleTextStyle"    TargetType="TextBlock" BasedOn="{StaticResource Text.Title}"/>
  <Style x:Key="BodyTextStyle"     TargetType="TextBlock" BasedOn="{StaticResource Text.Body}"/>
  <Style x:Key="LabelTextStyle"    TargetType="TextBlock" BasedOn="{StaticResource Text.Label}"/>
  <Style x:Key="FiguresTextStyle"  TargetType="TextBlock" BasedOn="{StaticResource Text.Figures}"/>

</ResourceDictionary>
