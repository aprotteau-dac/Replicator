      <DrawingGroup>
        <DrawingGroup.ClipGeometry>
          <RectangleGeometry Rect="0,0,24,24"/>
        </DrawingGroup.ClipGeometry>
      <GeometryDrawing>
        <GeometryDrawing.Pen>
          <Pen Brush="{DynamicResource Brush.Ink.Icon}" Thickness="2" LineJoin="Miter" StartLineCap="Square" EndLineCap="Square"/>
        </GeometryDrawing.Pen>
        <GeometryDrawing.Geometry>
          <RectangleGeometry Rect="3,4,18,16"/>
        </GeometryDrawing.Geometry>
