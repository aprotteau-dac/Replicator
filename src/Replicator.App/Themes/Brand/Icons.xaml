<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <FontIconSource x:Key="Icon.Backup" FontFamily="Segoe MDL2 Assets" Glyph="&#xE74E;" Foreground="{StaticResource TextPrimaryBrush}" />
    <FontIconSource x:Key="Icon.Shuttle" FontFamily="Segoe MDL2 Assets" Glyph="&#xE8FD;" Foreground="{StaticResource TextPrimaryBrush}" />
    <FontIconSource x:Key="Icon.Source" FontFamily="Segoe MDL2 Assets" Glyph="&#xE8B7;" Foreground="{StaticResource TextPrimaryBrush}" />
    <FontIconSource x:Key="Icon.Destination" FontFamily="Segoe MDL2 Assets" Glyph="&#xE838;" Foreground="{StaticResource TextPrimaryBrush}" />
    <FontIconSource x:Key="Icon.Prepare" FontFamily="Segoe MDL2 Assets" Glyph="&#xE895;" Foreground="{StaticResource TextPrimaryBrush}" />
    <FontIconSource x:Key="Icon.Depart" FontFamily="Segoe MDL2 Assets" Glyph="&#xE72A;" Foreground="{StaticResource AccentBrush}" />
    <FontIconSource x:Key="Icon.Dock" FontFamily="Segoe MDL2 Assets" Glyph="&#xE72B;" Foreground="{StaticResource AccentBrush}" />
    <FontIconSource x:Key="Icon.Receive" FontFamily="Segoe MDL2 Assets" Glyph="&#xE896;" Foreground="{StaticResource AccentBrush}" />
    <FontIconSource x:Key="Icon.Schedule" FontFamily="Segoe MDL2 Assets" Glyph="&#xE787;" Foreground="{StaticResource TextPrimaryBrush}" />
    <FontIconSource x:Key="Icon.DryRun" FontFamily="Segoe MDL2 Assets" Glyph="&#xE9D9;" Foreground="{StaticResource AccentBrush}" />
    <FontIconSource x:Key="Icon.Locked" FontFamily="Segoe MDL2 Assets" Glyph="&#xE72E;" Foreground="{StaticResource WarningBrush}" />
    <FontIconSource x:Key="Icon.Conflict" FontFamily="Segoe MDL2 Assets" Glyph="&#xE783;" Foreground="{StaticResource WarningBrush}" />
    <FontIconSource x:Key="Icon.Drive" FontFamily="Segoe MDL2 Assets" Glyph="&#xEDA2;" Foreground="{StaticResource TextPrimaryBrush}" />
    <FontIconSource x:Key="Icon.Identity" FontFamily="Segoe MDL2 Assets" Glyph="&#xE77B;" Foreground="{StaticResource TextPrimaryBrush}" />
</ResourceDictionary>
